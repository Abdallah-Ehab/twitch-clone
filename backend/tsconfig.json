{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",          // Better for modern Node ESM
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,          // Essential to ignore mismatched library types
    "esModuleInterop": true,       // Helps with importing commonjs like jsonwebtoken
    "sourceMap": true,
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*"]
}
